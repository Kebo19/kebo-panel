"use client";

import { useState } from "react";
import { useRouter } from "next/navigation";
import { supabase } from "@/lib/supabase";

export default function LoginPage() {
  const router = useRouter();

  const [username, setUsername] = useState("");
  const [password, setPassword] = useState("");
  const [errorText, setErrorText] = useState("");
  const [loading, setLoading] = useState(false);

  async function login() {
    try {
      setLoading(true);
      setErrorText("");

      console.log("LOGIN TIKLANDI");

      const { data, error } = await supabase
        .from("profiles")
        .select("*");

      console.log("SUPABASE DATA:", data);
      console.log("SUPABASE ERROR:", error);

      if (error) {
        setErrorText(
          JSON.stringify(error)
        );
        setLoading(false);
        return;
      }

      const user = data?.find(
        (x) =>
          x.email === username.trim() &&
          x.password === password.trim()
      );

      console.log("BULUNAN USER:", user);

      if (!user) {
        setErrorText(
          "Kullanıcı adı veya şifre hatalı"
        );
        setLoading(false);
        return;
      }

      localStorage.setItem(
        "kebo_user",
        JSON.stringify(user)
      );

      router.push("/");
    } catch (err) {
      console.error(err);
      setErrorText(
        "Beklenmeyen hata oluştu"
      );
    }

    setLoading(false);
  }

  return (
    <main className="min-h-screen flex items-center justify-center bg-[#07090d] text-white">

      <div className="w-full max-w-md bg-[#111315] border border-white/10 rounded-3xl p-8">

        <h1 className="text-3xl font-black text-center mb-8">
          KEBO YÖNETİM PANELİ
        </h1>

        <div className="space-y-4">

          <input
            value={username}
            onChange={(e) =>
              setUsername(e.target.value)
            }
            placeholder="Kullanıcı Adı"
            className="w-full h-12 px-4 rounded-xl bg-[#0d1117] border border-white/10"
          />

          <input
            type="password"
            value={password}
            onChange={(e) =>
              setPassword(e.target.value)
            }
            placeholder="Şifre"
            className="w-full h-12 px-4 rounded-xl bg-[#0d1117] border border-white/10"
          />

          {errorText && (
            <div className="bg-red-500/10 border border-red-500/20 text-red-400 p-3 rounded-xl text-sm">
              {errorText}
            </div>
          )}

          <button
            onClick={login}
            disabled={loading}
            className="w-full h-12 bg-orange-500 text-black font-black rounded-xl"
          >
            {loading
              ? "Kontrol Ediliyor..."
              : "Panele Giriş Yap"}
          </button>

        </div>

      </div>

    </main>
  );
}
