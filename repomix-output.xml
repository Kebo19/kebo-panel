"use client";

import { useState } from "react";
import { supabase } from "@/lib/supabase";

export default function YeniPersonelPage() {
  const [fullName, setFullName] = useState("");
  const [department, setDepartment] = useState("");
  const [tc, setTc] = useState("");
  const [iban, setIban] = useState("");
  const [birthDate, setBirthDate] = useState("");
  const [startDate, setStartDate] = useState("");

  async function savePersonel() {
    const { error } = await supabase.from("personnels").insert([
      {
        full_name: fullName,
        department,
        tc,
        iban,
        birth_date: birthDate,
        start_date: startDate,
      },
    ]);

    if (error) {
      alert(JSON.stringify(error));
      return;
    }

    alert("Personel kaydedildi");

    setFullName("");
    setDepartment("");
    setTc("");
    setIban("");
    setBirthDate("");
    setStartDate("");
  }

  return (
    <main className="min-h-screen bg-[#0f0f0f] text-white pb-32">
      <div className="px-5 pt-10">
        <p className="text-orange-500 text-sm font-medium">PERSONEL EKLE</p>
