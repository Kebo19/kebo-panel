<file path="app/personeller/page.tsx">
"use client";

import Link from "next/link";

import { useEffect, useMemo, useState } from "react";

import { useSearchParams } from "next/navigation";

import Topbar from "@/components/Topbar";

import { Card } from "@/components/ui/card";

import { Input } from "@/components/ui/input";

import {
  ChefHat,
  Bike,
  Sparkles,
  Store,
  Plus,
  ChevronDown,
  X,
} from "lucide-react";

const initialPersonnel = {
  mutfak: [],

  banko: [],

  kurye: [],

  temizlik: [],
};

export default function PersonellerPage() {

  const searchParams =
    useSearchParams();

  const [tab, setTab] =
    useState(
      searchParams.get("tab") === "ayrilan"
        ? "ayrilan"
        : "aktif"
    );

  const [showModal, setShowModal] =
    useState(false);

  const [allPersonnel, setAllPersonnel] =
    useState<any>(initialPersonnel);

  const [openSections, setOpenSections] =
    useState<any>({
      mutfak: true,
      banko: false,
      kurye: false,
      temizlik: false,
    });

  const [form, setForm] =
    useState({
      id: Date.now(),

      name: "",

      phone: "",

      tc: "",

      iban: "",

      salary: "",

      department: "mutfak",

      startDate: "",

      status: "Aktif",

      note: "",
    });

  useEffect(() => {

    const savedPersonnel =
      localStorage.getItem(
        "allPersonnel"
      );

    if (savedPersonnel) {

      setAllPersonnel(
        JSON.parse(savedPersonnel)
      );

    }

  }, []);

  useEffect(() => {

    localStorage.setItem(
      "allPersonnel",
      JSON.stringify(allPersonnel)
    );

  }, [allPersonnel]);

  const filteredPersonnel =
    Object.fromEntries(

      Object.entries(
        allPersonnel
      ).map(([key, value]: any) => [

        key,

        value.filter((person: any) =>

          tab === "aktif"
            ? person.status !== "İşten Ayrıldı"
            : person.status === "İşten Ayrıldı"

        ),

      ])

    );

  function toggleSection(section: string) {

    setOpenSections((prev: any) => ({
      ...prev,
      [section]: !prev[section],
    }));
  }

  function addPersonnel() {

    if (!form.name) return;

    const updated = {
      ...allPersonnel,

      [form.department]: [
        ...allPersonnel[
          form.department
        ],

        form,
      ],
    };

    setAllPersonnel(updated);

    setShowModal(false);

    setForm({
      id: Date.now(),

      name: "",

      phone: "",

      tc: "",

      iban: "",

      salary: "",

      department: "mutfak",

      startDate: "",

      status: "Aktif",

      note: "",
    });
  }

  return (

    <main className="min-h-screen bg-[#07090d] text-white p-4">

      <Topbar />

      <div className="flex items-center justify-between mb-6">

        <div>

          <p className="text-orange-400 text-[10px] uppercase tracking-[0.3em] font-black">
            KEBO ERP
          </p>

          <h1 className="text-5xl font-black mt-3">
            Personeller
          </h1>

        </div>

        <button
          onClick={() => setShowModal(true)}
          className="
            h-14
            px-6
            rounded-2xl
            bg-orange-500
            text-black
            font-black
            flex
            items-center
            gap-3
          "
        >

          <Plus size={20} />

          Personel Ekle

        </button>

      </div>

      <div className="flex gap-3 mb-6">

        <button
          onClick={() => setTab("aktif")}
          className={`
            h-12
            px-5
            rounded-2xl
            font-black
            transition-all

            ${
              tab === "aktif"
                ? "bg-orange-500 text-black"
                : "bg-[#111315] text-white"
            }
          `}
        >
          Aktif Personeller
        </button>

        <button
          onClick={() => setTab("ayrilan")}
          className={`
            h-12
            px-5
            rounded-2xl
            font-black
            transition-all

            ${
              tab === "ayrilan"
                ? "bg-orange-500 text-black"
                : "bg-[#111315] text-white"
            }
          `}
        >
          Ayrılan Personeller
        </button>

      </div>

      <div className="space-y-5">

        <PersonnelSection
          title="Mutfak"
          sectionKey="mutfak"
          icon={
            <ChefHat
              size={22}
              className="text-orange-400"
            />
          }
          open={openSections.mutfak}
          toggle={toggleSection}
          personnel={filteredPersonnel.mutfak}
        />

        <PersonnelSection
          title="Banko"
          sectionKey="banko"
          icon={
            <Store
              size={22}
              className="text-blue-400"
            />
          }
          open={openSections.banko}
          toggle={toggleSection}
          personnel={filteredPersonnel.banko}
        />

        <PersonnelSection
          title="Kurye"
          sectionKey="kurye"
          icon={
            <Bike
              size={22}
              className="text-green-400"
            />
          }
          open={openSections.kurye}
          toggle={toggleSection}
          personnel={filteredPersonnel.kurye}
        />

        <PersonnelSection
          title="Temizlik"
          sectionKey="temizlik"
          icon={
            <Sparkles
              size={22}
              className="text-purple-400"
            />
          }
          open={openSections.temizlik}
          toggle={toggleSection}
          personnel={filteredPersonnel.temizlik}
        />

      </div>

      {
        showModal && (

          <div
            className="
              fixed
              inset-0
              bg-black/70
              backdrop-blur-sm
              flex
              items-center
              justify-center
              z-50
              p-4
            "
          >

            <Card className="bg-[#111315] border border-white/5 rounded-3xl p-6 w-full max-w-2xl">

              <div className="flex items-center justify-between mb-6">

                <div>

                  <p className="text-orange-400 text-[10px] uppercase tracking-[0.3em] font-black">
                    PERSONEL
                  </p>

                  <h2 className="text-3xl font-black mt-2">
                    Personel Ekle
                  </h2>

                </div>

                <button
                  onClick={() => setShowModal(false)}
                  className="
                    w-12
                    h-12
                    rounded-2xl
                    bg-[#0d1117]
                    flex
                    items-center
                    justify-center
                  "
                >

                  <X size={20} />

                </button>

              </div>

              <div className="grid grid-cols-1 xl:grid-cols-2 gap-4">

                <Input
                  placeholder="Ad Soyad"
                  value={form.name}
                  onChange={(e) =>
                    setForm({
                      ...form,
                      name: e.target.value,
                    })
                  }
                />

                <Input
                  placeholder="Telefon"
                  value={form.phone}
                  onChange={(e) =>
                    setForm({
                      ...form,
                      phone: e.target.value,
                    })
                  }
                />

                <Input
                  placeholder="TC Kimlik No"
                  value={form.tc}
                  onChange={(e) =>
                    setForm({
                      ...form,
                      tc: e.target.value,
                    })
                  }
                />

                <div className="relative">

                  <div
                    className="
                      absolute
                      left-4
                      top-1/2
                      -translate-y-1/2
                      text-gray-400
                      font-black
                      z-10
                    "
                  >
                    TR
                  </div>

                  <Input
                    placeholder="0001 2000 0000 1234 5678 90"
                    value={form.iban}
                    onChange={(e) =>
                      setForm({
                        ...form,
                        iban: e.target.value,
                      })
                    }
                    className="pl-14"
                  />

                </div>

                <Input
                  placeholder="Maaş"
                  value={form.salary}
                  onChange={(e) =>
                    setForm({
                      ...form,
                      salary: e.target.value,
                    })
                  }
                />

                <select
                  value={form.department}
                  onChange={(e) =>
                    setForm({
                      ...form,
                      department: e.target.value,
                    })
                  }
                  className="
                    w-full
                    h-14
                    rounded-2xl
                    bg-[#0d1117]
                    border
                    border-white/5
                    px-4
                    text-white
                    outline-none
                  "
                >

                  <option value="mutfak">
                    Mutfak
                  </option>

                  <option value="banko">
                    Banko
                  </option>

                  <option value="kurye">
                    Kurye
                  </option>

                  <option value="temizlik">
                    Temizlik
                  </option>

                </select>

                <Input
                  type="date"
                  value={form.startDate}
                  onChange={(e) =>
                    setForm({
                      ...form,
                      startDate: e.target.value,
                    })
                  }
                />

                <select
                  value={form.status}
                  onChange={(e) =>
                    setForm({
                      ...form,
                      status: e.target.value,
                    })
                  }
                  className="
                    w-full
                    h-14
                    rounded-2xl
                    bg-[#0d1117]
                    border
                    border-white/5
                    px-4
                    text-white
                    outline-none
                  "
                >

                  <option value="Aktif">
                    Aktif
                  </option>

                  <option value="İşten Ayrıldı">
                    İşten Ayrıldı
                  </option>

                </select>

              </div>

              <textarea
                placeholder="Notlar"
                value={form.note}
                onChange={(e) =>
                  setForm({
                    ...form,
                    note: e.target.value,
                  })
                }
                className="
                  w-full
                  h-32
                  rounded-2xl
                  bg-[#0d1117]
                  border
                  border-white/5
                  p-4
                  text-white
                  outline-none
                  resize-none
                  mt-4
                "
              />

              <button
                onClick={addPersonnel}
                className="
                  w-full
                  h-14
                  rounded-2xl
                  bg-orange-500
                  text-black
                  font-black
                  mt-4
                "
              >

                Personeli Kaydet

              </button>

            </Card>

          </div>

        )
      }

    </main>

  );
}

function PersonnelSection({
  title,
  icon,
  personnel,
  open,
  toggle,
  sectionKey,
}: any) {

  const sortedPersonnel =
    useMemo(() => {

      return [...personnel].sort(
        (a, b) =>
          a.name.localeCompare(
            b.name,
            "tr"
          )
      );

    }, [personnel]);

  return (

    <Card className="bg-[#111315] border border-white/5 rounded-3xl overflow-hidden">

      <button
        onClick={() =>
          toggle(sectionKey)
        }
        className="
          w-full
          p-5
          flex
          items-center
          justify-between
          hover:bg-white/5
          transition-all
        "
      >

        <div className="flex items-center gap-4">

          <div
            className="
              w-14
              h-14
              rounded-2xl
              bg-[#0d1117]
              flex
              items-center
              justify-center
            "
          >

            {icon}

          </div>

          <div className="text-left">

            <p className="text-xs text-gray-500">
              Departman
            </p>

            <h2 className="text-3xl font-black">
              {title}
            </h2>

          </div>

        </div>

        <ChevronDown
          size={24}
          className={`
            transition-all
            duration-300
            ${
              open
                ? "rotate-180"
                : ""
            }
          `}
        />

      </button>

      {
        open && (

          <div className="px-5 pb-5">

            <div className="space-y-3">

              {
                sortedPersonnel.length === 0 && (

                  <div
                    className="
                      bg-[#0d1117]
                      rounded-2xl
                      p-5
                      text-center
                      text-gray-500
                    "
                  >

                    Personel bulunamadı

                  </div>

                )
              }

              {
                sortedPersonnel.map(
                  (person: any) => (

                    <Link
                      key={person.id}
                      href={`/personeller/${person.id}`}
                    >

                      <div
                        className="
                          bg-[#0d1117]
                          rounded-2xl
                          p-4
                          flex
                          items-center
                          justify-between
                          hover:bg-[#161b22]
                          transition-all
                          cursor-pointer
                        "
                      >

                        <div>

                          <h2 className="font-black text-xl">
                            {person.name}
                          </h2>

                          <p className="text-sm text-gray-500 mt-1">
                            {person.phone}
                          </p>

                        </div>

                        <div className="text-right">

                          <p className="text-xs text-gray-500">
                            Durum
                          </p>

                          <h2
                            className={`
                              font-black
                              mt-1
                              text-lg

                              ${
                                person.status ===
                                "İşten Ayrıldı"
                                  ? "text-red-400"
                                  : "text-green-400"
                              }
                            `}
                          >
                            {person.status}
                          </h2>

                        </div>

                      </div>

                    </Link>

                  )
                )
              }

            </div>

          </div>

        )
      }

    </Card>

  );
}
