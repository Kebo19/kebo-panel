"use client";

import { useEffect, useState } from "react";

import Link from "next/link";

import { useParams } from "next/navigation";

import Topbar from "@/components/Topbar";

import { Card } from "@/components/ui/card";

import { Input } from "@/components/ui/input";

import {
  ArrowLeft,
  Phone,
  CreditCard,
  Landmark,
  Users,
  CalendarDays,
  FileText,
  Wallet,
  Save,
} from "lucide-react";

export default function PersonelDetayPage() {

  const params = useParams();

  const [person, setPerson] =
    useState<any>(null);

  useEffect(() => {

    const saved =
      localStorage.getItem(
        `person-${params.id}`
      );

    if (saved) {

      setPerson(JSON.parse(saved));

    } else {

      setPerson({
        id: params.id,
        name: "Ahmet Kaya",
        phone: "0555 555 55 55",
        tc: "12345678910",
        iban: "0001 2000 0000 1234 5678 90",
        department: "Mutfak",
        salary: "38.000 ₺",
        startDate: "2024-03-12",
        exitDate: "",
        status: "Aktif",
        note: "Akşam vardiyasında görev alıyor.",
      });

    }

  }, [params.id]);

  function handleSave() {

    if (!person) return;

    if (person.exitDate) {

      const confirmed =
        window.confirm(
          "Bu personel Ayrılan Personeller bölümüne taşınacaktır. Onaylıyor musunuz?"
        );

      if (!confirmed) return;

      const updatedPerson = {
        ...person,
        status: "İşten Ayrıldı",
      };

      setPerson(updatedPerson);

      localStorage.setItem(
        `person-${person.id}`,
        JSON.stringify(updatedPerson)
      );

      window.location.href =
        "/personeller?tab=ayrilan";

      return;
    }

    localStorage.setItem(
      `person-${person.id}`,
      JSON.stringify(person)
    );

    alert("Değişiklikler kaydedildi.");
  }

  if (!person) return null;

