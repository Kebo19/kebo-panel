            className="w-full bg-[#2a2a2a] mt-3 rounded-2xl p-4 outline-none"
          />
        </div>

        <div className="bg-[#1a1a1a] rounded-3xl p-5">
          <p className="text-sm text-gray-500">Bölüm</p>
          <select
            value={department}
            onChange={(e) => setDepartment(e.target.value)}
